PORT=3500
NODE_ENV=development
DATA_DIR=./data
JWT_SECRET=your-secret-key-change-this
OWNER_PASSWORD=your-owner-password

# MongoDB (if set, uses MongoDB instead of filesystem storage)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/website-cms

# Vercel deployment token (for publishing sites)
VERCEL_TOKEN=your-vercel-token

# OpenRouter API key (for AI chat editing)
OPENROUTER_API_KEY=sk-or-v1-your-key
